# 1. 載入所需嘅 Library
install.packages("RStoolbox")
library(RStoolbox)
library(terra)
# 2. 載入 RStoolbox 內置嘅 Landsat 範例數據 (lsat)
# 呢個數據集係原始嘅 Digital Numbers (DN)
data(lsat)
# 3. 睇吓未修正前張相係點 (通常會比較「白蒙蒙」)
plotRGB(lsat, r = 3, g = 2, b = 1, stretch = "lin", main = "Original (With Haze)")
# 4. 第一步：估算薄霧值 (Estimate Haze)
# 我們假設影像入面最暗嘅 1% 像素 (darkProp = 0.01) 應該係黑體
# hazeBands 揀 1:3 係因為藍、綠、紅光最受大氣散射影響
haze_values <- estimateHaze(lsat, hazeBands = 1:3, darkProp = 0.01, plot = TRUE)
# 5. 第二步：執行 DOS 修正 (radCor 函數)
# method = "dos" 會自動減去大氣雜訊
lsat_corrected <- radCor(lsat, metaData = NULL, method = "dos", hazeValues = haze_values)
