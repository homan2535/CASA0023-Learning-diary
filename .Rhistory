# ==========================================
# CASA0023 Practical 3: 大氣修正 (DOS) 完整教學
# ==========================================
# 第一步：安裝並載入必要嘅工具 (Packages)
# 如果你已經裝咗，呢兩行唔會重複裝
if (!require("RStoolbox")) install.packages("RStoolbox")
if (!require("terra")) install.packages("terra")
library(RStoolbox)
library(terra)
# 第二步：載入範例數據 (Landsat DN 數據)
data(lsat)
# 第三步：準備 Meta-data (呢度係重點！)
# 由於 lsat 係內置數據，佢其實已經帶有一份基礎資料。
# 我哋要確保 radCor 讀得到呢份資料。
# 喺現實中，呢步通常係用 readMeta("你的MTL文件路徑.txt")
lsat_info <- readMeta(NULL) # 建立空殼
# 1. 載入工具
library(RStoolbox)
library(terra)
# 2. 載入數據 (lsat 係一個 RasterStack)
data(lsat)
# 3. 估算薄霧值 (Haze)
# 呢步會幫你搵出 Band 1, 2, 3 入面最暗嘅數值
haze_values <- estimateHaze(lsat, hazeBands = 1:3, darkProp = 0.01, plot = TRUE)
print(haze_values) # 睇吓搵到邊三個數
# 4. 執行 DOS 修正 (手動減法)
# DOS 嘅原理就係：修正後數值 = 原始數值 - 大氣雜訊 (Haze)
# 我哋將成張相複製一份出嚟做修正
lsat_corrected <- lsat
# 逐個波段減去對應嘅 Haze 值
lsat_corrected[[1]] <- lsat[[1]] - haze_values[1]
lsat_corrected[[2]] <- lsat[[2]] - haze_values[2]
lsat_corrected[[3]] <- lsat[[3]] - haze_values[3]
# 確保減完之後唔會有負數 (細過 0 嘅變返做 0)
lsat_corrected[lsat_corrected < 0] <- 0
# 5. 畫圖對比
par(mfrow = c(1, 2))
# 原始圖 (Raw)
plotRGB(lsat, r = 3, g = 2, b = 1, stretch = "lin", main = "Original")
# 修正圖 (Corrected)
plotRGB(lsat_corrected, r = 3, g = 2, b = 1, stretch = "lin", main = "DOS Corrected")
# 6. 睇吓 Histogram 嘅變化
dev.new()
hist(lsat[[1]], main="Band 1: Raw (Red) vs DOS (Blue)", col=rgb(1,0,0,0.5), xlim=c(0,250))
hist(lsat_corrected[[1]], col=rgb(0,0,1,0.5), add=TRUE)
