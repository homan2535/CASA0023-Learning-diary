haze_values <- estimateHaze(lsat, hazeBands = 1:3, darkProp = 0.01, plot = TRUE)
print(haze_values) # 睇吓搵到邊三個數
# 4. 執行 DOS 修正 (手動減法)
# DOS 嘅原理就係：修正後數值 = 原始數值 - 大氣雜訊 (Haze)
# 我哋將成張相複製一份出嚟做修正
lsat_corrected <- lsat
# 逐個波段減去對應嘅 Haze 值
lsat_corrected[[1]] <- lsat[[1]] - haze_values[1]
lsat_corrected[[2]] <- lsat[[2]] - haze_values[2]
lsat_corrected[[3]] <- lsat[[3]] - haze_values[3]
# 確保減完之後唔會有負數 (細過 0 嘅變返做 0)
lsat_corrected[lsat_corrected < 0] <- 0
# 5. 畫圖對比
par(mfrow = c(1, 2))
