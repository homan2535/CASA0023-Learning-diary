# ==========================================
# Macau Remote Sensing Analysis (NDVI & Texture)
# Based on RSCE Method by Christy Choi
# ==========================================
# --- Step 0: 載入工具 (確保你已經 install.packages 過) ---
library(terra)
library(raster)
library(glcm)
# --- Step 1: 設定檔案路徑 (用返你提供嘅 Path) ---
path_b4 <- "/Users/homanchan/Downloads/LC08_L2SP_122045_20250319_20250327_02_T1/LC08_L2SP_122045_20250319_20250327_02_T1_SR_B4.TIF"
path_b5 <- "/Users/homanchan/Downloads/LC08_L2SP_122045_20250319_20250327_02_T1/LC08_L2SP_122045_20250319_20250327_02_T1_SR_B5.TIF"
# 讀取為 SpatRaster (terra 格式)
b4 <- rast(path_b4)
b5 <- rast(path_b5)
# --- Step 2: 計算 NDVI (植被指數) ---
# 公式: (NIR - Red) / (NIR + Red)
ndvi <- (b5 - b4) / (b5 + b4)
# 定義綠色系顏色盤
ndvi_cols <- colorRampPalette(c("brown", "yellow", "green", "darkgreen"))(100)
# 畫 NDVI 圖
plot(ndvi, col = ndvi_cols, main = "Macau NDVI (Vegetation Cover)")
# --- Step 3: 計算 Texture (紋理分析 - 城市形態) ---
# 1. 縮細影像 (Aggregate) 等 Mac 跑得快啲 (10倍縮圖)
b4_small <- aggregate(b4, fact = 10)
# 2. 轉做舊格式 RasterLayer 嚟配合 glcm package
b4_old <- raster(b4_small)
# 3. 計算 GLCM Texture (Contrast 對比度)
# 呢步會跑大約 5-10 秒
texture_contrast <- glcm(b4_old, window = c(3, 3), statistics = "contrast")
# --- Step 4: 執靚 Texture 嘅顏色 (黃綠色調) ---
# 定義 Christy 嗰種黃綠色盤
my_colors <- colorRampPalette(c("white", "yellow", "orange", "green", "darkgreen"))(100)
# 自動搵出 95% 嘅數值範圍，避免極端值 (Outliers) 令顏色變淡
# 呢步係解決你「顏色唔出」嘅關鍵
vals <- values(texture_contrast)
upper_limit <- quantile(vals, 0.95, na.rm
# ==========================================
# Macau Urban Texture Analysis (Only)
# ==========================================
# 1. 載入必要工具
library(terra)
library(raster)
library(glcm)
# 2. 讀取 Band 4 (Red Band)
path_b4 <- "/Users/homanchan/Downloads/LC08_L2SP_122045_20250319_20250327_02_T1/LC08_L2SP_122045_20250319_20250327_02_T1_SR_B4.TIF"
b4 <- rast(path_b4)
# 3. 縮細影像 (10倍) 提高運算速度，並轉為舊格式
# 喺 Urban Spatial Science 入面，縮小可以減少雜訊，睇到更大規模嘅城市形態
b4_small <- aggregate(b4, fact = 10)
b4_old <- raster(b4_small)
# 4. 計算 Texture (Contrast - 對比度)
# 呢個指標最能區分「高密度舊區」同「平整新發展區」
texture_result <- glcm(b4_old, window = c(3, 3), statistics = "contrast")
# 5. 執靚顏色 (模擬 Christy 嘅黃綠色調)
# 我們使用 quantile 嚟自動設定顏色範圍，廢事啲色太淡
my_colors <- colorRampPalette(c("white", "yellow", "orange", "green", "darkgreen"))(100)
upper_val <- quantile(values(texture_result), 0.95, na.rm = TRUE)
# 6. 出圖
plot(texture_result,
col = my_colors,
zlim = c(0, upper_val),
main = "Macau Urban Morphology (Texture)",
axes = TRUE)
# --- (可選) 儲存高品質圖片 ---
# writeRaster(texture_result, "Macau_Texture_Result.tif", overwrite=TRUE)
